# ========== DATABASE CONFIGURATION ==========
# اترك هذا فارغاً للاستخدام المحلي (JSON)
# أو ضع Connection String لاستخدام PostgreSQL

# DATABASE_URL=postgresql://postgres.xxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ========== INSTRUCTIONS ==========
# على جهازك المحلي:
#   - احذف السطر أو اتركه فارغاً → يستخدم JSON
#
# على Koyeb/VPS:
#   - ضع Connection String كامل → يستخدم PostgreSQL
#
# Connection String من Supabase:
#   postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres
